{
  "name": "onskeskyen-playwright-tests",
  "version": "1.0.0",
  "description": "Playwright E2E test suite for onskeskyen.dk",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
