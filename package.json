    "test:update-snapshots": "playwright test --update-snapshots",
    "test:auth": "playwright test tests/auth.setup.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.0"
  }
}
